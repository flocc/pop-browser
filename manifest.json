{
  "manifest_version": 3,
  "name": "Polish Our Prices",
  "version": "1.0",
  "description": "xyz",
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [{
    "matches": [
      "https://store.steampowered.com/app/*/*",
      "https://steamcommunity.com/*"
    ],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "web_accessible_resources": [{
    "resources": [
      "style.css",
      "icons/*.svg"
    ],
    "matches": ["https://store.steampowered.com/*" ]
  }],
  "host_permissions": ["https://polishourprices.pl/*"],
  "permissions": ["scripting", "tabs"],
  "browser_specific_settings": {
    "gecko": { "id": "xyz@polishourprices.pl" }
  }
}
